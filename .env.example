
# ==========================================
# OkayProject Backend Environment Variables
# ==========================================
# 실제 API 키는 이 파일에 넣지 않습니다.
# 이 파일은 필요한 환경변수 이름을 공유하기 위한 예시 파일입니다.
# 로컬에서는 터미널 export 또는 .env 파일을 사용하고,
# Render 배포 시에는 Render Dashboard의 Environment Variables에 등록합니다.


# ------------------------------------------
# Weather / Rainfall API
# ------------------------------------------
# 기상청 API Hub 인증키
KMA_API_KEY=

# Current 1-hour rainfall provider for backend inference.
CURRENT_RAINFALL_API_URL=https://apihub.kma.go.kr/api/typ01/cgi-bin/url/nph-dfs_vsrt_grd?vars=RN1
CURRENT_RAINFALL_API_KEY=
CURRENT_RAINFALL_API_KEY_PARAM=authKey
CURRENT_RAINFALL_API_SOURCE=kma-apihub
CURRENT_RAINFALL_API_TIMEOUT_SECONDS=5

# Daily accumulated rainfall provider for rainfall_total.
KMA_TIME_OBS_API_URL=https://apihub.kma.go.kr/api/typ01/url/kma_sfctm2.php
KMA_ASOS_STATION_ID=108

# ------------------------------------------
# Police Missing Person API
# ------------------------------------------
# 공공데이터포털 경찰청 실종경보정보 API 인증키
POLICE_MISSING_API_KEY=

# 경찰청 실종경보정보 API 요청 URL
POLICE_MISSING_API_URL=


# ------------------------------------------
# Kakao Local API
# ------------------------------------------
# 카카오 Developers에서 발급받은 REST API 키
# 주소/장소명 → 좌표 변환, 좌표 → 주소 변환에 사용
KAKAO_REST_API_KEY=


# ------------------------------------------
# Gemini API
# ------------------------------------------
# Google AI Studio에서 발급받은 Gemini API 키
# 사용자 맞춤 재난 행동요령 문장 생성에 사용
GEMINI_API_KEY=

# 사용할 Gemini 모델명
# 기본값으로 gemini-2.0-flash 사용
GEMINI_MODEL=gemini-2.0-flash
